{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "types": ["bun-types"]
  },
  "include": [
    ".opencode/plugins/**/*.ts",
    "plugins/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".git",
    "dist",
    "**/*.test.ts"
  ]
}
